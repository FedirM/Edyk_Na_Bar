# Sender bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID where the second bot receives messages.
# Use a GROUP id (e.g. -1001234567890) where BOTH bots are members — NOT your user id or bot id.
TARGET_CHAT_ID=

# Your Telegram user ID — only you can use the sender bot (recommended)
ALLOWED_USER_ID=

# Random secret string for webhook validation (use the same value in setWebhook)
WEBHOOK_SECRET=
