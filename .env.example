# Sender bot token from @BotFather (receives messages from anyone)
TELEGRAM_BOT_TOKEN=

# Target/staff bot token — the bot that delivers orders to staff (from file.html)
TARGET_BOT_TOKEN=

# Chat ID where staff receives messages (same as TG_CHAT_ID in file.html, e.g. 5184403466)
TARGET_CHAT_ID=

# Random secret string for webhook validation (use the same value in setWebhook)
WEBHOOK_SECRET=
